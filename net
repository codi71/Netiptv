# 🛡️ ## --- MONITORIZARE INTELIGENTĂ APARATE ȘI IP-URI (MIDDLEWARE CENTRAL) ---
# ----------------------------------------------------------------------
@app.middleware("http")
async def log_client_connections(request: Request, call_next):
    # 1. Extragere IP real din Cloudflare / Proxy-uri
    ip_real = request.headers.get("CF-Connecting-IP")
    if not ip_real:
        x_forwarded = request.headers.get("X-Forwarded-For", "")
        ip_real = x_forwarded.split(",")[0].strip() if x_forwarded else request.client.host
    
    # 2. Forțăm Uvicorn să folosească IP-ul real în logurile sale interne
    try:
        old_client = request.scope.get("client")
        port = old_client.port if old_client else 0
        request.scope["client"] = Address(host=ip_real, port=port)
    except Exception:
        try:
            request.scope["client"] = (ip_real, 0)
        except Exception:
            pass

    # 🛑 3. VERIFICARE VERDICT: Dacă IP-ul este deja blocat permanent sau temporar
    if ip_real in IP_BLOCATE_RAM:
        return Response("Acces Interzis. IP-ul tau a fost blocat permanent.", status_code=403)

    # --- VERIFICARE BAN TEMPORAR PROGRESIV ÎN RAM ---
    acum_timestamp = time.time()
    if ip_real in IP_BANATE_TEMPORAR:
        # Dacă timpul de ban a expirat, îl eliberăm automat în siguranță
        if acum_timestamp > IP_BANATE_TEMPORAR[ip_real]:
            IP_BANATE_TEMPORAR.pop(ip_real, None)
            print(f"{get_now()} [{CLR_INFO}BAN EXPIRED{CLR_RESET}] IP-ul {ip_real} a ispășit pedeapsa și a fost deblocat.")
        else:
            timp_ramas = int(IP_BANATE_TEMPORAR[ip_real] - acum_timestamp)
            # Transformăm secundele rămase în minute/ore citibile pentru utilizator
            if timp_ramas > 3600:
                text_ramas = f"{timp_ramas // 3600}h și {(timp_ramas % 3600) // 60}m"
            else:
                text_ramas = f"{timp_ramas // 60}m și {timp_ramas % 60}s"
            return Response(f"Acces Interzis. Esti banat temporar pentru triasare. Timp ramas: {text_ramas}.", status_code=403)

    cale_ceruta = request.url.path

    # 🛑 4. SCUTUL AUTO-DEFENSIV: Dacă un IP nou accesează o rută de bot mizerabilă
    if cale_ceruta in RUTE_INTERZISE:
        if ip_real not in IP_BLOCATE_RAM:
            with write_lock:
                try:
                    with open(BLACKLIST_PATH, "a", encoding="utf-8") as f:
                        f.write(f"{ip_real}\n")
                except Exception as e_write_bl:
                    print(f"[-] Eroare la scrierea pe disc în blacklist: {e_write_bl}")
                IP_BLOCATE_RAM.add(ip_real)
            print(f"{get_now()} [{CLR_ALERT}FIREWALL AUTOMAT{CLR_RESET}] IP-ul {CLR_ALERT}{ip_real}{CLR_RESET} a accesat ruta de bot '{cale_ceruta}'. Blacklisted!")

        return Response("Acces Interzis. IP blocat.", status_code=403)

    # 🛑 5. PROTECȚIE METODĂ HTTP VERB INSPECTION
    if request.method not in ["GET", "HEAD"] and cale_ceruta == "/":
        if ip_real not in IP_BLOCATE_RAM:
            with write_lock:
                try:
                    with open(BLACKLIST_PATH, "a", encoding="utf-8") as f:
                        f.write(f"{ip_real}\n")
                except Exception as e_write_bl:
                    print(f"[-] Eroare la scrierea pe disc în blacklist: {e_write_bl}")
                IP_BLOCATE_RAM.add(ip_real)
            print(f"{get_now()} [{CLR_ALERT}FIREWALL METODĂ{CLR_RESET}] IP-ul {CLR_ALERT}{ip_real}{CLR_RESET} blocat pentru metodă invalidă: {CLR_ALERT}{request.method}{CLR_RESET}!")
        return Response("Metoda Nepermisa.", status_code=405)
    # ----------------------------------------------------------------------
    # 📝 6. DETECTARE APARATE ACTUALIZATĂ (INCLUDE PALETA DE CULORI CLR_DEV ȘI NEEDLE)
    # ----------------------------------------------------------------------
    user_agent = request.headers.get("user-agent", "Aparat Necunoscut").lower()


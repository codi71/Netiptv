def verifica_rate_limit_ip(ip: str, user_id="WebPage") -> bool:
    """
    Verifică dacă un IP a depășit limita de 5 cereri pe minut.
    Dacă o depășește, aplică logica ta de penalizare progresivă în RAM!
    """
    acum = time.time()
    
    if ip not in ISTORIC_CERERI_IP:
        ISTORIC_CERERI_IP[ip] = [acum]
        return True
        
    # Păstrăm doar cererile din ultimele 60 de secunde
    ISTORIC_CERERI_IP[ip] = [t for t in ISTORIC_CERERI_IP[ip] if acum - t < 60]
    
    # Dacă a trecut de limita de 5 cereri pe minut:
    if len(ISTORIC_CERERI_IP[ip]) >= 5:
        # Incrementăm numărul de abateri înregistrate pentru acest IP
        RECIDIVISTI_CONTOR[ip] = RECIDIVISTI_CONTOR.get(ip, 0) + 1
        abateri = RECIDIVISTI_CONTOR[ip]
        
        if abateri == 1:
            durata_ban = 10 * 60
            text_durata = "10m"
        else:
            durata_ban = (abateri - 1) * 60 * 60
            text_durata = f"{abateri - 1}h"
            
        # Îl blocăm pe loc în structura ta globală de FIREWALL RAM
        IP_BANATE_TEMPORAR[ip] = acum + durata_ban
        
        # Printează o singură dată alerta mare în consolă, apoi middleware-ul îl va reduce la tăcere
        print(f"{get_now()} [{CLR_ALERT}RATE BAN{CLR_RESET}] ID: {CLR_RUN}{user_id}{CLR_RESET} IP: {CLR_RUN}{ip}{CLR_RESET}. Spam intens (Abaterea {abateri}). Salvam in RAM {text_durata}.")
        return False
        
    ISTORIC_CERERI_IP[ip].append(acum)
    return True


def reseteaza_ram_din_consola(signum, frame):
    """Golește toate blocajele (Abuz, Chei Invalide, Firewall ambele liste) la semnalul SIGUSR2"""
    # 1. Deblocare din RAM pentru toate tipurile de ban temporar fără să stricăm streamingul

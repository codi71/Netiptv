def translate_gemini(texts_dict, target_lang, api_key, model_name, timeout=API_TIMEOUT, thinking_level=THINKING_LEVEL):
    url = f"https://generativelanguage.googleapis.com/v1alpha/models/{model_name}:generateContent?key={api_key}"
    
    # 1. Transformăm codul scurt în numele complet al limbii pentru AI folosind dicționarul global
    lang_info = LANGUAGES_DATA.get(str(target_lang).lower(), {"lang3": "", "name": f"{str(target_lang).upper()} language", "flag": ""})
    limba_finala = lang_info["name"]

    # 2. Generăm promptul dinamic în funcție de limba dorită de utilizator
    prompt = f"""
You are an expert subtitle translator. Translate the 'text' values of the following JSON data strictly into {limba_finala}.
Keep the 'index' fields completely unchanged. 
Return ONLY the raw JSON array containing objects with 'index' and 'text'. No markdown formatting, no explanation.
"""

    json_input = [{"index": str(k), "text": v} for k, v in texts_dict.items()]


    generation_config = {
        "temperature": 0.3,  
        "response_mime_type": "application/json",
        "responseSchema": {
            "type": "ARRAY",
            "items": {
                "type": "OBJECT",
                "properties": {
                    "index": {"type": "STRING"},
                    "text": {"type": "STRING"}
                },
                "required": ["index", "text"]
            }
        }
    }

    if thinking_level and thinking_level.lower() != "off":
        generation_config["thinkingConfig"] = {"thinkingLevel": thinking_level.upper()}

    payload = {
        "contents": [{"parts": [{"text": prompt + "\n\n" + json.dumps(json_input, ensure_ascii=False)}]}],
        "generationConfig": generation_config,
        "safetySettings": [
            {"category": "HARM_CATEGORY_HARASSMENT", "threshold": "BLOCK_NONE"},
            {"category": "HARM_CATEGORY_HATE_SPEECH", "threshold": "BLOCK_NONE"},
            {"category": "HARM_CATEGORY_SEXUALLY_EXPLICIT", "threshold": "BLOCK_NONE"},
            {"category": "HARM_CATEGORY_DANGEROUS_CONTENT", "threshold": "BLOCK_NONE"},
            {"category": "HARM_CATEGORY_CIVIC_INTEGRITY", "threshold": "BLOCK_NONE"},
        ],
    }

    try:
        response = requests.post(url, json=payload, headers={'Content-Type': 'application/json'}, timeout=timeout)
        
        # 🛡️ FIX SINTAXĂ: Tratăm cheile invalide sau blocate de Google instant (400/403)
        if response.status_code in [400, 403]:
            return None, -1

        if response.status_code == 200:
            res_data = response.json()
            candidates = res_data.get('candidates', [])
            if candidates and isinstance(candidates, list) and len(candidates) > 0:
                first_candidate = candidates[0]
                if first_candidate.get('finishReason', '') == 'SAFETY':
                    return None, 0
                parts = first_candidate.get('content', {}).get('parts', [])
                if parts and len(parts) > 0:
                    text_r = parts[0].get('text', '').strip()
                    if text_r.startswith("```"):
                        text_r = re.sub(r"^```(?:json)?\n|\n```$", "", text_r).strip()
                    
                    # 🛡️ FIX: Prindem eroarea de string neterminat separat și dăm codul -2
                    try:
                        parsed_array = json.loads(text_r)
                        return {str(item['index']): str(item['text']) for item in parsed_array if 'index' in item and 'text' in item}, 0
                    except json.JSONDecodeError as json_err:
                        print(f"[-] JSON neterminat de la Gemini (Unterminated string): {json_err}")
                        return None, -2
                        
        return None, response.status_code
    except Exception as e:
        print(f"[-] Eroare la apelarea Gemini API: {e}")
        return None, 500



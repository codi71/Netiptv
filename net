def get_subtitles(api_keys: str, video_type: str, imdb_id: str, lang: str, extra: str = None):
    id_parts = imdb_id.split(":")
    imdb_clean = id_parts[0].replace("tt", "")
    if len(id_parts) == 3:
        season, episode = id_parts[1], id_parts[2]
        query_path = f"episode-{episode}/imdbid-{imdb_clean}/season-{season}"
    else:
        query_path = f"imdbid-{imdb_clean}"

    subtitles_list = []
    os_url = f"https://rest.opensubtitles.org/search/{query_path}"
    try:
        # Adăugăm proxies=... ca să ocolim host-ul greșit '_' din VPS
        r = requests.get(os_url, headers={'User-Agent': 'HotSubtitlesV1'}, proxies={"http": None, "https": None}, timeout=10)
        if r.ok:
            for item in r.json():
                sub_id = item.get('IDSubtitleFile')
                sub_name = item.get('SubFileName', 'Subtitle')
                lang_code = item.get('ISO639', 'en')
                lang_name = item.get('LanguageName', 'Unknown')
                lang_id = item.get('SubLanguageID', 'eng')

                if lang_code != lang.lower():
                    # 🌟 Căutăm limba în dicționarul global. Dacă nu există, punem globul 🌐 ca valoare implicită
                    lang_info = LANGUAGES_DATA.get(lang.lower(), {"lang3": "", "name": f"{lang.upper()} language", "flag": "🌐"})
                    steag_tinta = lang_info["flag"] if lang_info["flag"] else "🌐"
                    
                    subtitles_list.append({
                        "id": f"{lang}-{steag_tinta}-{sub_name[:30]}",
                        "url": f"https://{DOMENIU_PUBLIC}/gemini/api_keys={api_keys}_lang={lang}/translate/{sub_id}.srt",
                        "lang": lang_id, 
                        "label": f"{lang}-{steag_tinta}-{sub_name[:30]}"
                    })
    except Exception as e:
        print(f"[-] Eroare căutare Gemini Multi-Key: {e}")
    return {"subtitles": subtitles_list}





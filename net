# 🚀 5. COADA ASINCRONĂ NATIVĂ (Varianta ta originală stabilă cu Monitorizare Loturi + Auto-Conversie Universală)
        async def translation_stream_generator():
            lock_dobandit = False
            try:
                while True:
                    if await request.is_disconnected():
                        print(f"{get_now()} [{CLR_ALERT}QUEUE CANCEL{CLR_RESET}] ID: {CLR_RUN}{id_utilizator_scurt}{CLR_RESET} IP: {CLR_RUN}{ip_real}{CLR_RESET} a abandonat în timp ce aștepta în coadă.")
                        return

                    if not gemini_speed_lock.locked():
                        await gemini_speed_lock.acquire()
                        lock_dobandit = True
                        break
                    yield " "
                    await asyncio.sleep(0.5)

                if os.path.exists(cache_path):
                    with open(cache_path, "r", encoding="utf-8") as f:
                        yield f.read()
                    return

                if await request.is_disconnected():
                    print(f"{get_now()} [{CLR_ALERT}QUEUE CANCEL{CLR_RESET}] ID: {CLR_RUN}{id_utilizator_scurt}{CLR_RESET} a abandonat exact când îi venea rândul.")
                    return

                oameni_ramasi = len(active_ips) - 1 if len(active_ips) > 0 else 0
                print(f"{get_now()} [{CLR_RUN}GEMINI Traduce{CLR_RESET}] ID: {CLR_RUN}{id_utilizator_scurt}{CLR_RESET} IP: {CLR_RUN}{ip_real}{CLR_RESET}  [{lang.upper()}] | Rămași la coadă: {oameni_ramasi}")

                download_url = f"https://subs5.strem.io/en/download/subencoding-stremio-utf8/src-api/file/{sub_id}"
                
                try:
                    srt_response = requests.get(download_url, timeout=12)
                    if not srt_response.ok:
                        # 🔍 LOG PENTRU SERVER STREMIO DOWN SAU SUBTITRARE NEEXISTENTĂ
                        print(f"{get_now()} [{CLR_ALERT}SUB DOWNLOAD ERR{CLR_RESET}] Stremio responded with Status: {srt_response.status_code} for User ID: {id_utilizator_scurt} | SubID: {sub_id}")
                        
                        RECIDIVISTI_CONTOR[id_utilizator_scurt] = RECIDIVISTI_CONTOR.get(id_utilizator_scurt, 0) + 1
                        if RECIDIVISTI_CONTOR[id_utilizator_scurt] >= 4:
                            timp_viitor_ban = time.time() + 600
                            CACHE_CHEI_INVALIDE_RAM[id_utilizator_scurt] = timp_viitor_ban
                            IP_BANATE_TEMPORAR[ip_real] = timp_viitor_ban 
                            print(f"{get_now()} [{CLR_ALERT}AUTO-BAN ID{CLR_RESET}] ID: {CLR_RUN}{id_utilizator_scurt}{CLR_RESET} BANNED 10m for failed requests spam.")
                        
                        chunk_down_err = (
                            "1\n00:00:01,000 --> 00:50:00,000\n"
                            "⚠️ [GEMINI AI] STREMIO PROVIDER IS UNRESPONSIVE!\n"
                            "The connection to the Stremio subtitle database timed out or failed.\n"
                            "Please wait a few seconds and retry, or select a different stream link.\n\n"
                        )
                        yield chunk_down_err
                        await asyncio.sleep(4) 
                        return

                    content = srt_response.text.replace("\r", "")

                    # 🔍 [DETECȚIE ȘI CONVERSIE UNIVERSALĂ DIRECT PE DISC]
                    # Identificăm dacă fișierul este ASS, WebVTT sau MicroDVD (bazați pe markup-uri specifice din fișiere)
                    este_format_alternativ = "[Script Info]" in content or "WEBVTT" in content or re.search(r'\{\d+\}\{\d+\}', content)

                    if este_format_alternativ:
                        print(f"{get_now()} [{CLR_RUN}-/ASS/VTT/SUB/{CLR_RESET}] ID: {CLR_RUN}{id_utilizator_scurt}{CLR_RESET} | SubID: {sub_id}. Se pornește conversia disc...")
                        
                        cale_temporara_srt = os.path.join(CACHE_DIR, f"temp_conv_{sub_id}.srt")
                        
                        try:
                            # 🚀 1. Încarcă structura alternativă (pysubs2 detectează automat tipul de text: ASS, SSA, VTT sau SUB)
                            sub_obiect = pysubs2.SSAFile.from_string(content)
                            
                            # 🚀 2. Salvează fișierul fizic ca SRT standardizat pe disc
                            sub_obiect.save(cale_temporara_srt, format_="srt")
                            #print(f"{get_now()} [{CLR_RUN}DISC SAVE{CLR_RESET}] Subtitrarea convertită  a fost salvată în: {cale_temporara_srt}")
                            
                            # 🚀 3. Citim fișierul SRT nativ înapoi în variabila content
                            with open(cale_temporara_srt, "r", encoding="utf-8", errors="ignore") as f_temp:
                                content = f_temp.read().replace("\r", "")
                                
                            #print(f"{get_now()} [{CLR_RUN}CONVERSIE OK{CLR_RESET}] Subtitrarea a fost transformată cu succes în SRT curat prin disc.")
                            
                            # 🚀 4. Curățăm fișierul temporar de pe VPS
                            if os.path.exists(cale_temporara_srt):
                                os.remove(cale_temporara_srt)
                                
                        except Exception as conv_err:
                            print(f"{get_now()} [{CLR_ALERT}CONVERSIE ERR{CLR_RESET}] Eșec la conversia: {conv_err}. Se încearcă procesarea brută.")
                            if os.path.exists(cale_temporara_srt):
                                os.remove(cale_temporara_srt)

                    # Parsare text garantat SRT curat, standardizat global
                    blocks = re.findall(r'(\d+)\s*\n(\d{2}:\d{2}:\d{2}[.,]\d{3} --> \d{2}:\d{2}:\d{2}[.,]\d{3})\s*\n([\s\S]*?)(?=\n\n|$)', content)
                    
                    if not blocks:
                        vtt_blocks = re.findall(r'(\d{2}:\d{2}:\d{2}[.,]\d{3} --> \d{2}:\d{2}:\d{2}[.,]\d{3})\s*\n([\s\S]*?)(?=\n\n|$)', content)
                        # Mapăm corect structura asșteptată de 3 elemente pentru VTT: (id, timestamp, text)
                        blocks = [(str(i+1), b[0], b[1]) for i, b in enumerate(vtt_blocks)]

                    if not blocks:
                        # 🔍 LOG PENTRU FIȘIER GOL / INVALID TRIMIS DE BOT
                        print(f"{get_now()} [{CLR_ALERT}SUB FORMAT ERR{CLR_RESET}] Downloaded subtitle is empty or invalid for User ID: {id_utilizator_scurt} | SubID: {sub_id}")
                        
                        RECIDIVISTI_CONTOR[id_utilizator_scurt] = RECIDIVISTI_CONTOR.get(id_utilizator_scurt, 0) + 1
                        if RECIDIVISTI_CONTOR[id_utilizator_scurt] >= 4:
                            timp_viitor_ban = time.time() + 600
                            CACHE_CHEI_INVALIDE_RAM[id_utilizator_scurt] = timp_viitor_ban
                            IP_BANATE_TEMPORAR[ip_real] = timp_viitor_ban 
                            print(f"{get_now()} [{CLR_ALERT}AUTO-BAN ID{CLR_RESET}] ID: {CLR_RUN}{id_utilizator_scurt}{CLR_RESET} BANNED 10m for empty file spam.")
                        
                        chunk_format_err = (
                            "1\n00:00:01,000 --> 00:50:00,000\n"
                            "⚠️ [GEMINI AI] SELECTED SUBTITLE LINK IS CORRUPT OR EMPTY!\n"
                            "The file downloaded from Stremio servers does not contain valid text blocks.\n"
                            "Please go back to your stream settings and choose an alternative subtitle link.\n\n"
                        )
                        yield chunk_format_err
                        await asyncio.sleep(4) 
                        return

                    if id_utilizator_scurt in CONTOR_ABUZ_FILME:
                        CONTOR_ABUZ_FILME[id_utilizator_scurt] = 0
                    if id_utilizator_scurt in RECIDIVISTI_CONTOR:
                        RECIDIVISTI_CONTOR[id_utilizator_scurt] = 0

                    total_lines = len(blocks)
                    batches = []
                    if total_lines > 0:
                        batches.append(blocks[:FIRST_BATCH_SIZE])
                        restul_blocurilor = blocks[FIRST_BATCH_SIZE:]
                        for i in range(0, len(restul_blocurilor), NEXT_BATCH_SIZE):
                            batches.append(restul_blocurilor[i:i + NEXT_BATCH_SIZE])

                    final_results = {}
                    loop = asyncio.get_running_loop()
                    
                    def run_threads():
                        with ThreadPoolExecutor(max_workers=4) as executor:
                            futures = {}
                            for idx, b in enumerate(batches):
                                futures[executor.submit(
                                    process_batch_worker, 
                                    b, 
                                    lang.lower(), 
                                    chei_valide_structural, 
                                    (FIRST_BATCH_TIMEOUT if idx == 0 else API_TIMEOUT),
                                    id_utilizator_scurt,
                                    ip_real
                                )] = idx

                            for future in as_completed(futures):
                                if asyncio.run_coroutine_threadsafe(request.is_disconnected(), loop).result():
                                    return
                                idx = futures[future]
                                try:
                                    res_srt, _, _ = future.result()
                                    if res_srt:
                                        with write_lock: 
                                            final_results[idx] = res_srt
                                except Exception as batch_err:
                                    print(f"{get_now()} [{CLR_ALERT}BATCH ERR{CLR_RESET}] Lotul {idx+1} a eșuat: {batch_err}")

                    translation_task = loop.run_in_executor(None, run_threads)

                    while not translation_task.done():
                        if await request.is_disconnected():
                            print(f"{get_now()} [{CLR_ALERT}QUEUE CANCEL{CLR_RESET}] ID: {CLR_RUN}{id_utilizator_scurt}{CLR_RESET} a închis Stremio în timpul traducerii.")
                            return
                        yield " "  
                        await asyncio.sleep(2)

                    await translation_task

                    if await request.is_disconnected():
                        return

                    full_srt = "".join([final_results[i] for i in sorted(final_results.keys()) if i in final_results])
                    if not full_srt.strip(): 
                        full_srt = content  # Reține conversia SRT curată dacă Gemini dă un rate-limit total

                    with open(cache_path, "w", encoding="utf-8") as f_o:
                        f_o.write(full_srt)

                    yield full_srt

                    print(f"{get_now()} [{CLR_COOL}GEMINI Tradusă{CLR_RESET}] ID: {CLR_COOL}{id_utilizator_scurt}{CLR_RESET} IP: {CLR_COOL}{ip_real}{CLR_RESET}  SubID: {sub_id} Pauză 30s")
                    
                    cooling_timer = 0
                    while cooling_timer < 30:
                        if await request.is_disconnected():
                            break
                        await asyncio.sleep(1)
                        cooling_timer += 1

                except Exception as stream_err:
                    print(f"{get_now()} [{CLR_ALERT}STREAM ERR{CLR_RESET}] Eroare în generatorul live: {stream_err}")
                    return
            finally:
                if lock_dobandit:
                    gemini_speed_lock.release()

                async with active_ips_lock:
                    if id_utilizator_scurt in active_users:
                        active_users.remove(id_utilizator_scurt)
                    if ip_real in active_ips:
                        active_ips.remove(ip_real)
                        print(f"{get_now()} [{CLR_INFO}GEMINI RELEASE{CLR_RESET}] ID: {CLR_INFO}{id_utilizator_scurt}{CLR_RESET} IP: {CLR_INFO}{ip_real}{CLR_RESET} Eliberat.")

                async with film_activ_lock:
                    if id_utilizator_scurt in film_activ_per_user:
                        del film_activ_per_user[id_utilizator_scurt]
                    if ip_real in film_activ_per_ip:
                        del film_activ_per_ip[ip_real]

                async with printat_coada_lock:
                    cheie_print = f"{ip_real}_{sub_id}"
                    if cheie_print in printat_coada:
                        printat_coada.remove(cheie_print)

        # 🚀 6. EXPEDIERE RESPONS STREAMING CĂTRE CADDY
        headers_nc = {
            "Cache-Control": "no-store, no-cache, must-revalidate, max-age=0",
            "Pragma": "no-cache",
            "Expires": "0"
        }
        return StreamingResponse(translation_stream_generator(), media_type="text/srt; charset=utf-8", headers=headers_nc)

    except Exception as e:
        print(f"{get_now()} [{CLR_ALERT}CRITICAL ERR{CLR_RESET}] Eroare critică Runner Gemini: {e}")
        
    finally:
        pass

    return Response(content="Eroare", media_type="text/plain")


# --- CURĂȚARE AUTOMATĂ CACHE (MAI VECHI DE 30 ZILE) ȘI LOGURI ---
def curata_linii_text(cale_fisier, linii_ramase=10):
    """Deschide logul de conexiuni și păstrează doar ultimele 10 linii"""
    if not os.path.exists(cale_fisier):
        return
    
    try:
        with open(cale_fisier, 'r', encoding='utf-8') as f:
            linii = f.readlines()
        
        if len(linii) > linii_ramase:
            ultimele_linii = linii[-linii_ramase:]
            
            with open(cale_fisier, 'w', encoding='utf-8') as f:
                f.writelines(ultimele_linii)
            print(f"{get_now()} [CACHE CLEANER] Fișierul {cale_fisier} a fost trunchiat la ultimele {linii_ramase} linii.")
            
    except Exception as e:
        print(f"{get_now()} [CACHE CLEANER ERROR] Nu s-a putut curăța fișierul text: {str(e)}")


async def curata_cache_vechi():
    """Rulează în fundal o dată pe zi și șterge fișierele mai vechi de 30 de zile + curăță logul"""
    cale_absoluta_log = os.path.abspath(LOG_FILE_PATH)
    
    while True:
        try:
            acum = time.time()
            limita_30_zile = acum - (30 * 24 * 60 * 60)
            fisiere_sterse = 0
            
            # 1. Curățarea folderului de cache (codul tău original)
            if os.path.exists(CACHE_DIR):
                for folder_radacina, _, fisiere in os.walk(CACHE_DIR):
                    for fisier in fisiere:
                        if fisier.endswith('.json') or fisier.endswith('.srt'):
                            cale_completa = os.path.join(folder_radacina, fisier)
                            timp_modificare = os.path.getmtime(cale_completa)
                            
                            if timp_modificare < limita_30_zile:
                                os.remove(cale_completa)
                                fisiere_sterse += 1
            
            if fisiere_sterse > 0:
                print(f"{get_now()} [CACHE CLEANER] S-au curățat {fisiere_sterse} fișiere mai vechi de 30 de zile.")
            else:
                print(f"{get_now()} [CACHE CLEANER] Scanare finalizată. Zero fișiere expirate.")
                
            # 2. Curățarea fișierului gemini_conexiuni_v2.txt la ultimele 10 linii
            curata_linii_text(cale_absoluta_log, linii_ramase=10)
                
        except Exception as e:
            print(f"{get_now()} [CACHE CLEANER ERROR] Problemă la curățare: {str(e)}")
            
        await asyncio.sleep(86400)



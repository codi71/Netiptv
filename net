    # Construim lista totală de prioritizare: cheile utilizatorului + cheile din pool-ul global ca fallback
    pool_keys = [k for k in get_shared_pool_keys() if k not in user_keys]
    random.shuffle(pool_keys) # Amestecăm pool-ul comun la întâmplare
    

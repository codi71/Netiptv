        cheie_a_avut_succes = False
        try:
            for model in MODEL_PREFERAT:
                # 🛡️ FIX LOCAL RETRY: Încercăm de maximum 2 ori pe aceeași cheie dacă JSON-ul vine trunchiat (-2)
                rezultat = None
                err_code = 0
                max_local_retries = 2
                
                for retry_idx in range(max_local_retries):
                    rezultat, err_code = translate_gemini(to_translate, target_lang, current_key, model, timeout=timeout_current)
                    
                    if rezultat is not None:
                        break  # Succes, ieșim din bucla de retry
                    if err_code != -2:
                        break  # Dacă e eroare fatală (-1) sau alt cod HTTP, nu dăm retry pe loc
                        
                    if retry_idx < max_local_retries - 1:
                        print(f"🔄 [{CLR_QUEUE}JSON RETRY{CLR_RESET}] Răspuns neterminat de la {model} (Cheie index {k_idx_real}). Reîncercăm pe loc în 1.5s({retry_idx+1}/{max_local_retries-1})")
                        time.sleep(1.5)
                
                if rezultat is not None:
                    cheie_a_avut_succes = True
                    chunk_srt = ""
                    for b_id, timing, orig_text in batch:
                        trad = rezultat.get(str(b_id), skipped_lines.get(str(b_id), orig_text))
                        trad = str(trad).replace('- ', '').strip()
                        trad = split_smart_long_line(trad, max_chars=44)
                        linii = [l.strip().lstrip('- ').strip() for l in trad.splitlines()]
                        final_text = "\n".join(linii)
                        chunk_srt += "{}\n{}\n{}\n\n".format(b_id, timing, final_text)
                    
                    # Identificăm proveniența sursei pentru statistici
                    provenienta = f"UserKey-{k_idx_real}" if k_idx_real <= len(user_keys) else "CloudPool"
                    return chunk_srt, k_idx_real, f"{model} ({provenienta})"
                
                if err_code == -1: 
                    return None, 0, ""
                    
                print(f"⚠️ [!] Cheia index {k_idx_real} a eșuat pe modelul {model} pentru ID: {user_id}. Încercăm următorul...")
                
                # ⏱️ PAUZĂ Scurtă între modele ca să nu blocăm IP-ul din prima milisecundă
                time.sleep(1.0)
                
            tried_keys_indices.add(k_idx_real - 1)
            
            # Dacă cheia curentă a eșuat pe TOATE modelele din listă
            if not cheie_a_avut_succes:
                esecuri_consecutive_user += 1
                
                # 🛑 DETECTARE BRUTE-FORCE: La 15 eșecuri pe modele, înghețăm utilizatorul în RAM pentru 2 minute
                if esecuri_consecutive_user >= 15:
                    CACHE_CHEI_INVALIDE_RAM[user_id] = time.time() - 480  # 600 - 480 = 120s (2 minute ban)
                    print(f"🚨 [{CLR_ALERT}BRUTE-FORCE DETECTED{CLR_RESET}] User ID: {user_id} a epuizat cheile sau a generat prea multe erori. Banat în RAM pentru 2 minute.")
                    return None, 0, "Banned"

                # ⏱️ PAUZĂ GLOBALĂ DIN VARIABILA TA (Așteaptă 10 secunde înainte de cheia următoare)
                time.sleep(PAUZA_DUPA_EROARE)

        finally:
            with keys_lock:
                if current_key in keys_in_use: keys_in_use.remove(current_key)
                
    return None, 0, ""



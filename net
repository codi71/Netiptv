class DecodedAccessFormatter(AccessFormatter):
    """Interceptează, colorează și decodează automat textul URL-urilor în consolă"""
    def format(self, record: logging.LogRecord) -> str:
        if hasattr(record, "args") and isinstance(record.args, tuple) and len(record.args) > 2:
            try:
                args_list = list(record.args)
                # Decodează elementul URL (index 2) direct în tuplu
                args_list[2] = urllib.parse.unquote(args_list[2])
                record.args = tuple(args_list)
            except Exception:
                pass
        return super().format(record)

